---
import '@fontsource-variable/literata';
import '@fontsource-variable/literata/wght-italic.css';
import '@fontsource-variable/fraunces';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '@fontsource/ibm-plex-mono/600.css';
import '../styles/global.css';

const { title, description, ogImage = 'home', ogType = 'website' } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + '/';
// absolute URLs for social cards (crawlers require them). ogImage is a slug —
// 'home' or '<vendor>/<slug>' — resolved against the built /og/*.png endpoints.
const site = Astro.site ?? new URL('https://malob.github.io/');
const canonicalUrl = new URL(Astro.url.pathname, site).href;
const ogImageUrl = new URL(`${base}og/${ogImage}.png`, site).href;
---

<!doctype html>
<html lang="en" data-base={base}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta name="generator" content={Astro.generator} />

    <link rel="canonical" href={canonicalUrl} />
    <link rel="sitemap" href={`${base}sitemap-index.xml`} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="AI System Cards" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImageUrl} />

    <script is:inline>
      (() => {
        const saved = localStorage.getItem('theme');
        const theme = saved ?? (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.dataset.theme = theme;
      })();
    </script>
  </head>
  <body>
    <slot />
    <footer class="sitefoot">
      <p>
        Spot a glitch, or want to help make these conversions better?
        <a href="https://github.com/malob/ai-system-cards" target="_blank" rel="noopener"
          >Open an issue or a PR on GitHub</a
        >.
      </p>
      <p>
        Faithful HTML renderings of AI model system cards — every page links to the original PDF,
        and all document content belongs to its publisher.
      </p>
    </footer>
  </body>
</html>
