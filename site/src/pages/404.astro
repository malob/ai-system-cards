---
import Base from '../layouts/Base.astro';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + '/';
---

<Base title="Page not found — AI System Cards" description="That page isn’t in the archive.">
  <main class="home notfound">
    <p class="eyebrow">Error 404</p>
    <h1>Page<br />not found</h1>
    <p class="lede">
      That page isn’t in the archive — it may have moved, or never existed.
      <a href={base}>Head back to the homepage</a>.
    </p>
  </main>
</Base>
